# ─── AWS Credentials ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=ap-south-1

# ─── Model IDs ───────────────────────────────────────────────────────────────
CLAUDE_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
TITAN_EMBED_ID=amazon.titan-embed-text-v2:0

# ─── LLM Parameters ──────────────────────────────────────────────────────────
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
RAGAS_MAX_TOKENS=2048
LLM_MAX_CONCURRENCY=2

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=10000
CHUNK_OVERLAP=0
UNSTRUCTURED_MAX_CHARS=4000
UNSTRUCTURED_NEW_AFTER_N_CHARS=3800
UNSTRUCTURED_COMBINE_UNDER_N_CHARS=2000

# ─── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVER_K=6
IMAGE_MIN_DIMENSION=100
IMAGE_MAX_BYTES=5000000

# ─── Paths ───────────────────────────────────────────────────────────────────
WORK_DIR=./workspace
UPLOAD_DIR=./workspace/uploads
CHROMA_DIR=./workspace/chroma_db
IMG_DIR=./workspace/extracted_images
CHROMA_COLLECTION=dell_multimodal_rag

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]
LOG_LEVEL=INFO

# ─── Evaluation ──────────────────────────────────────────────────────────────
EVAL_RATE_LIMIT_SLEEP=2.0
